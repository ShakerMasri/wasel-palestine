{
  "info": {
    "_postman_id": "wasel-postman-collection",
    "name": "Wasel Local API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for the Wasel local NestJS API."
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "auth": {
              "type": "noauth"
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3006",
              "path": [
                "auth",
                "login"
              ]
            },
            "event": [
              {
                "listen": "test",
                "script": {
                  "type": "text/javascript",
                  "exec": [
                    "pm.test(\"Save JWT token\", function () {",
                    "  const jsonData = pm.response.json();",
                    "  pm.environment.set(\"token\", jsonData.access_token);",
                    "});"
                  ]
                }
              }
            ],
            "description": "Authenticate a user and return a token."
          }
        },
        {
          "name": "Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/profile",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3006",
              "path": [
                "auth",
                "profile"
              ]
            },
            "description": "Fetch the authenticated user profile."
          }
        }
      ]
    },
    {
      "name": "Incidents",
      "item": [
        {
          "name": "Create Incident",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"checkpointId\": 1,\n  \"status\": \"Open\",\n  \"description\": \"Incident description\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/incidents",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3006",
              "path": [
                "incidents"
              ]
            },
            "description": "Create a new incident report."
          }
        },
        {
          "name": "List Incidents",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/incidents",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3006",
              "path": [
                "incidents"
              ]
            },
            "description": "List all incidents with optional filters and pagination."
          }
        },
        {
          "name": "Update Incident",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Closed\",\n  \"description\": \"Updated incident details\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/incidents/:id",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3006",
              "path": [
                "incidents",
                ":id"
              ]
            },
            "description": "Update an incident by id."
          }
        },
        {
          "name": "Delete Incident",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/incidents/:id",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3006",
              "path": [
                "incidents",
                ":id"
              ]
            },
            "description": "Delete an incident by id."
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Create Report",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 1,\n  \"category\": \"traffic\",\n  \"description\": \"accident\",\n  \"latitude\": 31.95,\n  \"longitude\": 35.91\n}"
            },
            "url": {
              "raw": "{{base_url}}/reports",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3006",
              "path": [
                "reports"
              ]
            },
            "event": [
              {
                "listen": "test",
                "script": {
                  "type": "text/javascript",
                  "exec": [
                    "pm.test(\"Save report id\", function () {",
                    "  const jsonData = pm.response.json();",
                    "  pm.environment.set(\"report_id\", jsonData.id);",
                    "});"
                  ]
                }
              }
            ],
            "description": "Create a new user report."
          }
        },
        {
          "name": "Get Report By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/reports/{{report_id}}",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3006",
              "path": [
                "reports",
                "{{report_id}}"
              ]
            },
            "description": "Retrieve a single user report by id."
          }
        },
        {
          "name": "Update Report",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category\": \"traffic\",\n  \"description\": \"updated accident details\",\n  \"latitude\": 31.951,\n  \"longitude\": 35.911\n}"
            },
            "url": {
              "raw": "{{base_url}}/reports/{{report_id}}",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3006",
              "path": [
                "reports",
                "{{report_id}}"
              ]
            },
            "description": "Update a user report by id."
          }
        },
        {
          "name": "Delete Report",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/reports/{{report_id}}",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3006",
              "path": [
                "reports",
                "{{report_id}}"
              ]
            },
            "description": "Delete a user report by id."
          }
        }
      ]
    }
  ]
}